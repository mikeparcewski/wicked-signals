{
  "name": "wicked-signals",
  "version": "0.1.0",
  "description": "Inference and routing layer for the wicked-* ecosystem",
  "main": "./dist/cli.js",
  "bin": {
    "wicked-signals": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "@anthropic-ai/sdk": "^0.36.0",
    "commander": "^12.0.0",
    "express": "^4.18.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    }
  }
}
